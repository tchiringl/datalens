# =============================================================================
# Data Lens Retail AI POC — Environment Variables Template
# =============================================================================
# Copy this file to .env and replace placeholder values before running:
#   cp .env.example .env
# NEVER commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — primary relational store for retail data, Airflow metadata, and
# the Hive Metastore backing database.
# -----------------------------------------------------------------------------
POSTGRES_USER=datalens
POSTGRES_PASSWORD=datalens123
POSTGRES_DB=retail

# -----------------------------------------------------------------------------
# Airflow — Airflow uses a separate logical database on the same PostgreSQL
# instance. The Fernet key encrypts connection credentials stored in the DB.
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# -----------------------------------------------------------------------------
AIRFLOW_DB=airflow
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW_ADMIN_EMAIL=admin@datalens.local
AIRFLOW_UID=50000

# -----------------------------------------------------------------------------
# MinIO — S3-compatible object storage. The warehouse bucket holds Iceberg
# table data; the raw bucket is the landing zone for ingested files.
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_WAREHOUSE=warehouse
MINIO_BUCKET_RAW=raw

# -----------------------------------------------------------------------------
# Trino — distributed SQL query engine. These variables are used by the API
# service to construct the Trino connection string.
# -----------------------------------------------------------------------------
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=admin

# -----------------------------------------------------------------------------
# OpenMetadata — metadata catalog. Uses the same PostgreSQL instance with a
# dedicated database (openmetadata) created automatically on first run.
# -----------------------------------------------------------------------------
OM_HOST=openmetadata-server
OM_PORT=8585
OM_ADMIN_USER=admin
OM_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# API — FastAPI backend. SECRET_KEY signs session tokens; use a random 32-byte
# hex string in production:
#   python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
API_HOST=api
API_PORT=8000
SECRET_KEY=your-secret-key-here

# -----------------------------------------------------------------------------
# Frontend — Vite React SPA. VITE_API_BASE_URL is baked into the JS bundle at
# build time; change it before running `make up` if the API is on a remote host.
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8001
