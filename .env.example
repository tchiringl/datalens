# =============================================================================
# DataLens Minimal Dev — Environment Variables Template
# =============================================================================
# Copy this file to .env and replace placeholder values before running:
#   cp .env.example .env
# NEVER commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — primary relational store for retail data, Airflow metadata,
# and Nessie catalog backend database.
# -----------------------------------------------------------------------------
POSTGRES_USER=datalens
POSTGRES_PASSWORD=datalens123
POSTGRES_DB=retail

# Databases created by db/init.sql:
# - airflow (Airflow DAG scheduling metadata)
# - nessie (Iceberg catalog metadata via Project Nessie)
AIRFLOW_DB=airflow

# -----------------------------------------------------------------------------
# Airflow 3.x — Orchestration engine for dbt pipelines
# Generate Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED: AIRFLOW_ADMIN_PASSWORD must be set before starting
# -----------------------------------------------------------------------------
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_UID=50000

# -----------------------------------------------------------------------------
# MinIO — S3-compatible object storage for Iceberg data
# warehouse: Iceberg table data
# raw: Landing zone for ingested files
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_WAREHOUSE=warehouse
MINIO_BUCKET_RAW=raw

# -----------------------------------------------------------------------------
# Trino — Federated SQL query engine
# Catalogs: postgres (direct JDBC), iceberg (Nessie REST)
# Host/port within Docker network: trino:8080
# Host/port from local machine: localhost:8080
# -----------------------------------------------------------------------------
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=admin

# -----------------------------------------------------------------------------
# API — FastAPI backend
# REQUIRED: SECRET_KEY signs session tokens; generate a random 32-byte hex string
#   python -c "import secrets; print(secrets.token_hex(32))"
# defaults to: api:8000 (Docker network) / localhost:8000 (host machine)
# REQUIRED: AIRFLOW_ADMIN_PASSWORD (same as above, needed to auth with Airflow API)
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here

# -----------------------------------------------------------------------------
# Frontend — Vite React SPA
# VITE_API_BASE_URL: baked into JS bundle at build time. Change before `make up`
# if the API is on a remote host. Default: http://localhost:8000
# In Docker network: http://api:8000
# From local machine: http://localhost:8000
# From remote machine: http://<api-host>:8000
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
